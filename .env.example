# =====================================================================
# Ephesian configuration
# Copy this file to `.env` and edit the values, or run `npm run setup`
# =====================================================================

# --- Network ---------------------------------------------------------
# HTTP port the application listens on.
PORT=8787

# WebSocket port for real-time collaboration. Leave blank to share PORT.
WS_PORT=

# Public origin used to build invite links and email URLs (no trailing slash).
PUBLIC_ORIGIN=http://localhost:8787

# --- Security --------------------------------------------------------
# Long random string used to sign session cookies. Auto-generated on first run if blank.
SESSION_SECRET=

# Set to "true" only when serving over HTTPS so the cookie gets the Secure flag.
COOKIE_SECURE=false

# Trust X-Forwarded-* headers if behind a reverse proxy ("true" or "false").
TRUST_PROXY=false

# Password reset throttles. Window values are in milliseconds.
PASSWORD_RESET_REQUEST_IP_MAX=10
PASSWORD_RESET_REQUEST_IP_WINDOW_MS=3600000
PASSWORD_RESET_REQUEST_EMAIL_MAX=5
PASSWORD_RESET_REQUEST_EMAIL_WINDOW_MS=3600000
PASSWORD_RESET_CONFIRM_IP_MAX=20
PASSWORD_RESET_CONFIRM_IP_WINDOW_MS=900000

# --- Database --------------------------------------------------------
# SQLite file location (created automatically).
DATABASE_PATH=./data/ephesian.db

# --- Email -----------------------------------------------------------
# Leave SMTP_HOST blank to run in "console mode" — verification & invite links
# are printed to the terminal instead of emailed. Ideal for first-time setup.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=Ephesian <no-reply@example.com>

# --- Branding --------------------------------------------------------
APP_NAME=Ephesian

# --- WebAuthn --------------------------------------------------------
# These default to PUBLIC_ORIGIN. Override only if you know what you are doing.
WEBAUTHN_RP_NAME=Ephesian
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# --- Document defaults ----------------------------------------------
# Maximum number of collaborators that may be in a single document at once
# when the owner has not set a per-document limit. 0 = unlimited.
DEFAULT_DOCUMENT_CAPACITY=0
